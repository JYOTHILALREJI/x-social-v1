// prisma/schema.prisma

generator client {
  provider = "prisma-client-js" // FIXED: Must be prisma-client-js
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  //url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String    @unique
  password      String
  dob           DateTime
  role          Role      @default(USER)

  // Creator Verification Fields
  creatorStatus CreatorStatus @default(NONE)
  creatorProfile  CreatorProfile?
  idProofUrl    String?       
  verifiedAt    DateTime?

  walletBalance Int       @default(0)
  image         String?
  bio           String?
  gender        String?
  interestedIn  String?
  createdAt     DateTime  @default(now())
  
  sessions      Session[]
  posts         Post[]
  reels         Reel[]
  
  // Dating Relationships
  sentMatches     Match[]        @relation("SentMatches")
  receivedMatches Match[]        @relation("ReceivedMatches")
  interests       UserInterest[]
  
  // AI Companion Relationship
  aiConversations AIConversation[]
}

model CreatorProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id])
  categories        String[] // Lingerie, Nudity, etc.
  idProofUrl        String   // URL from S3/Cloudinary
  selfieUrl         String   // URL from S3/Cloudinary
  status            Status   @default(PENDING)
  createdAt         DateTime @default(now())
}

model Match {
  id         String      @id @default(cuid())
  senderId   String
  receiverId String
  status     MatchStatus @default(PENDING)
  createdAt  DateTime    @default(now())

  sender   User @relation("SentMatches", fields: [senderId], references: [id])
  receiver User @relation("ReceivedMatches", fields: [receiverId], references: [id])

  @@unique([senderId, receiverId])
}

model AIConversation {
  id        String    @id @default(cuid())
  userId    String
  persona   String    
  messages  Json      
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Interest {
  id    String @id @default(cuid())
  name  String @unique
  users UserInterest[]
}

model UserInterest {
  userId     String
  interestId String
  user       User     @relation(fields: [userId], references: [id])
  interest   Interest @relation(fields: [interestId], references: [id])

  @@id([userId, interestId])
}

model Post {
  id        String   @id @default(cuid())
  imageUrl  String
  caption   String?
  isPremium Boolean  @default(false)
  price     Int?     
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([authorId])
}

model Reel {
  id        String   @id @default(cuid())
  videoUrl  String
  caption   String?
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([authorId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum Role {
  USER
  CREATOR
  ADMIN
}

enum Status {
  PENDING
  APPROVED
  REJECTED
}

enum CreatorStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum MatchStatus {
  PENDING
  ACCEPTED
  REJECTED
}