generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String           @id @default(cuid())
  email                   String           @unique
  username                String           @unique
  name                    String?
  password                String
  dob                     DateTime
  role                    Role             @default(USER)
  creatorStatus           CreatorStatus    @default(NONE)
  idProofUrl              String?
  verifiedAt              DateTime?
  walletBalance           Int              @default(0)
  image                   String?
  bio                     String?
  gender                  String?
  interestedIn            String?
  isGhost                 Boolean          @default(false)
  isPrivateAccount        Boolean          @default(false)
  isActivityStatusEnabled Boolean          @default(true)
  lastSeen                DateTime         @default(now())
  twoFactorQuestion       String?
  twoFactorAnswer         String?
  loginAlerts             Boolean          @default(false)
  autoplayVideos          Boolean          @default(true)
  mutedWords              String[]         @default([])
  createdAt               DateTime         @default(now())
  followersCount          Int              @default(0)
  followingCount          Int              @default(0)
  subscribersCount        Int              @default(0)
  aiConversations         AIConversation[]
  blockedBy               Block[]          @relation("BlockedBy")
  blocking                Block[]          @relation("Blocking")
  creatorProfile          CreatorProfile?
  follows                 Follow[]         @relation("follower")
  followers               Follow[]         @relation("following")
  receivedMatches         Match[]          @relation("ReceivedMatches")
  sentMatches             Match[]          @relation("SentMatches")
  notifications           Notification[]
  posts                   Post[]
  comments                PostComment[]
  likedPosts              PostLike[]
  purchases               Purchase[]
  reels                   Reel[]
  reelComments            ReelComment[]
  likedReels              ReelLike[]
  upvotedReels            ReelUpvote[]
  revenues                Revenue[]        @relation("CreatorRevenue")
  spendings               Revenue[]        @relation("UserSpendings")
  sessions                Session[]
  stories                 Story[]
  storyViews              StoryMediaView[]
  interests               UserInterest[]
}

model Block {
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  blocked   User     @relation("BlockedBy", fields: [blockedId], references: [id])
  blocker   User     @relation("Blocking", fields: [blockerId], references: [id])

  @@id([blockerId, blockedId])
}

model Follow {
  followerId       String
  followingId      String
  status           String    @default("ACCEPTED")
  subscriptionTier Int       @default(0)
  expiresAt        DateTime?
  follower         User      @relation("follower", fields: [followerId], references: [id])
  following        User      @relation("following", fields: [followingId], references: [id])

  @@id([followerId, followingId])
}

model CreatorProfile {
  id         String   @id @default(cuid())
  userId     String   @unique
  categories String[]
  idProofUrl String
  selfieUrl  String
  tier1Price    Int      @default(0)
  tier1Duration Int      @default(30)
  tier2Price    Int      @default(0)
  tier2Duration Int      @default(30)
  tier3Price    Int      @default(0)
  tier3Duration Int      @default(30)
  status     Status   @default(PENDING)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

model Revenue {
  id        String   @id @default(cuid())
  creatorId String
  senderId  String?
  amount    Int
  type      String
  createdAt DateTime @default(now())
  postId    String?
  reelId    String?
  creator   User     @relation("CreatorRevenue", fields: [creatorId], references: [id])
  sender    User?    @relation("UserSpendings", fields: [senderId], references: [id])

  @@index([creatorId])
  @@index([senderId])
}

model Match {
  id         String      @id @default(cuid())
  senderId   String
  receiverId String
  status     MatchStatus @default(PENDING)
  createdAt  DateTime    @default(now())
  receiver   User        @relation("ReceivedMatches", fields: [receiverId], references: [id])
  sender     User        @relation("SentMatches", fields: [senderId], references: [id])

  @@unique([senderId, receiverId])
}

model AIConversation {
  id        String   @id @default(cuid())
  userId    String
  persona   String
  messages  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Interest {
  id    String         @id @default(cuid())
  name  String         @unique
  users UserInterest[]
}

model UserInterest {
  userId     String
  interestId String
  interest   Interest @relation(fields: [interestId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@id([userId, interestId])
}

model Post {
  id        String        @id @default(cuid())
  imageUrl  String
  caption   String?
  isPremium Boolean       @default(false)
  isPrivate Boolean       @default(false)
  price     Int?
  authorId  String
  createdAt DateTime      @default(now())
  author    User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments  PostComment[] @relation("PostComments")
  likes     PostLike[]    @relation("PostLikes")
  purchases Purchase[]

  @@index([authorId])
}

model Reel {
  id        String        @id @default(cuid())
  videoUrl  String
  caption   String?
  isPremium Boolean       @default(false)
  isPrivate Boolean       @default(false)
  price     Int?
  authorId  String
  createdAt DateTime      @default(now())
  purchases Purchase[]
  author    User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments  ReelComment[] @relation("ReelComments")
  likes     ReelLike[]    @relation("ReelLikes")
  upvotes   ReelUpvote[]  @relation("ReelUpvotes")

  @@index([authorId])
}

model Purchase {
  id        String   @id @default(cuid())
  userId    String
  postId    String?
  reelId    String?
  createdAt DateTime @default(now())
  post      Post?    @relation(fields: [postId], references: [id])
  reel      Reel?    @relation(fields: [reelId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, reelId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  device       String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SystemSettings {
  id          String   @id @default("default")
  platformFee Int      @default(20)
  updatedAt   DateTime @updatedAt
}

model PostLike {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  post      Post     @relation("PostLikes", fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model PostComment {
  id        String   @id @default(cuid())
  text      String
  userId    String
  postId    String
  createdAt DateTime @default(now())
  post      Post     @relation("PostComments", fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  message   String
  type      String   @default("SECURITY")
  isRead    Boolean  @default(false)
  relatedId String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ReelLike {
  id        String   @id @default(cuid())
  userId    String
  reelId    String
  createdAt DateTime @default(now())
  reel      Reel     @relation("ReelLikes", fields: [reelId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, reelId])
}

model ReelComment {
  id        String   @id @default(cuid())
  text      String
  userId    String
  reelId    String
  createdAt DateTime @default(now())
  reel      Reel     @relation("ReelComments", fields: [reelId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([reelId])
}

model ReelUpvote {
  id        String   @id @default(cuid())
  userId    String
  reelId    String
  createdAt DateTime @default(now())
  reel      Reel     @relation("ReelUpvotes", fields: [reelId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, reelId])
}

model Story {
  id        String       @id @default(cuid())
  authorId  String
  createdAt DateTime     @default(now())
  author    User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  media     StoryMedia[]

  @@index([authorId])
}

model StoryMedia {
  id        String           @id @default(cuid())
  storyId   String
  url       String
  type      String
  duration  Int
  order     Int              @default(0)
  createdAt DateTime         @default(now())
  expiresAt DateTime
  story     Story            @relation(fields: [storyId], references: [id], onDelete: Cascade)
  views     StoryMediaView[]

  @@index([storyId])
}

model StoryMediaView {
  id           String     @id @default(cuid())
  storyMediaId String
  userId       String
  viewedAt     DateTime   @default(now())
  media        StoryMedia @relation(fields: [storyMediaId], references: [id], onDelete: Cascade)
  viewer       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storyMediaId, userId])
}

enum Role {
  USER
  CREATOR
  ADMIN
}

enum Status {
  PENDING
  APPROVED
  REJECTED
}

enum CreatorStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum MatchStatus {
  PENDING
  ACCEPTED
  REJECTED
}
